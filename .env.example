# Quran Foundation API — Pre-Production
# Get credentials at: https://api-docs.quran.foundation
QF_ENV=prelive
VITE_QURAN_CLIENT_ID=your-client-id
QF_CLIENT_SECRET=your-client-secret

VITE_QURAN_OAUTH_URL=https://prelive-oauth2.quran.foundation/oauth2/token
VITE_QURAN_API_BASE=https://apis-prelive.quran.foundation/content/api/v4
VITE_QURAN_CLIENT_PORTAL=https://oauth2-client-prelive.quran.foundation
VITE_QURAN_CONTENT_BASE=https://apis-prelive.quran.foundation
VITE_QURAN_API_BASE=/api/quran
# OAuth redirect URI — must be registered for client b8ea12a7 in the QF portal
VITE_REDIRECT_URI=http://localhost:5173/auth/callback
# imgbb — for Pinterest sharing (get a free key at https://api.imgbb.com)
VITE_IMGBB_API_KEY=your-imgbb-api-key

# ── Quran Foundation — Content API (Production) ───────────────────────────────
# Used for fetching verses, translations, tafsir (client_credentials flow)




